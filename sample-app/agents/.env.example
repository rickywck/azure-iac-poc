# Local service wiring
PORT=8001

# Foundry / OpenAI
FOUNDRY_ENDPOINT=https://your-foundry-account.openai.azure.com/
FOUNDRY_API_KEY=your-foundry-api-key
FOUNDRY_MODEL=gpt-4mini
OPENAI_API_KEY=your-foundry-api-key

# Application Insights
APPLICATIONINSIGHTS_INSTRUMENTATION_KEY=your-instrumentation-key

# Optional tracing
LANGCHAIN_API_KEY=your-tracing-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
