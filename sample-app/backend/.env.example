# PostgreSQL
POSTGRES_USER=pocadmin
POSTGRES_PASSWORD=your-password-here
POSTGRES_HOST=your-postgres-server.postgres.database.azure.com
POSTGRES_DB=agentdb
POSTGRES_SSLMODE=require
# Remote Azure path can omit POSTGRES_PASSWORD and use Key Vault instead.
# KEY_VAULT_URL=https://your-key-vault.vault.azure.net/
# POSTGRES_PASSWORD_SECRET_NAME=postgres-admin-password

# Agents service
AGENT_SERVICE_URL=http://localhost:8001

# Storage
STORAGE_ACCOUNT_NAME=yourstorageaccount
STORAGE_ACCOUNT_KEY=your-storage-account-key

# Application Insights
APPLICATIONINSIGHTS_INSTRUMENTATION_KEY=your-instrumentation-key
