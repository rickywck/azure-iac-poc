      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-identity', parameters('containerAppAgentsName'))), '2023-01-31').principalId]"
    },
    "containerAppUIFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppUIName')), '2023-05-01').latestRevisionFqdn]"
    },
