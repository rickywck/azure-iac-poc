          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[parameters('logAnalyticsWorkspaceId')]",
            "sharedKey": "[parameters('logAnalyticsSharedKey')]"
          }
        }
      },
      "tags": "[parameters('tags')]"
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('{0}-identity', parameters('containerAppUIName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]"
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('{0}-identity', parameters('containerAppAgentsName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]"
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerAppUIName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-identity', parameters('containerAppUIName'))))]": {}
        }
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 80,
            "traffic": [
              {
                "weight": 100,
                "latestRevision": true
              }
            ]
          },
          "secrets": [
            {
              "name": "acr-password",
              "value": "[parameters('acrPassword')]"
            },
            {
              "name": "postgres-password",
              "value": "[parameters('postgresPassword')]"
            },
            {
              "name": "storage-key",
              "value": "[parameters('storageAccountKey')]"
            },
            {
              "name": "appinsights-connection-string",
              "value": "[parameters('appInsightsConnectionString')]"
            }
          ],
          "registries": [
            {
              "server": "[parameters('acrLoginServer')]",
              "username": "[parameters('acrUsername')]",
              "passwordSecretRef": "acr-password"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "ui",
              "image": "[format('{0}/{1}', parameters('acrLoginServer'), parameters('uiImageName'))]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1.0Gi"
              },
              "env": [
                {
                  "name": "BACKEND_UPSTREAM",
                  "value": "localhost:8000"
                },
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "secretRef": "appinsights-connection-string"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "port": 80,
                    "path": "/"
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                },
                {
                  "type": "Readiness",
                  "httpGet": {
                    "port": 80,
                    "path": "/"
                  },
                  "initialDelaySeconds": 5,
                  "periodSeconds": 5,
                  "timeoutSeconds": 3,
                  "failureThreshold": 3
                }
              ]
            },
            {
              "name": "backend",
              "image": "[format('{0}/{1}', parameters('acrLoginServer'), parameters('backendImageName'))]",
              "resources": {
                "cpu": "[json('1.0')]",
                "memory": "2.0Gi"
              },
              "env": [
                {
                  "name": "POSTGRES_HOST",
                  "value": "[parameters('postgresHost')]"
                },
                {
                  "name": "POSTGRES_PORT",
                  "value": "5432"
                },
                {
                  "name": "POSTGRES_DB",
                  "value": "[parameters('postgresDatabase')]"
                },
                {
                  "name": "POSTGRES_USER",
                  "value": "[parameters('postgresUsername')]"
                },
                {
                  "name": "POSTGRES_PASSWORD",
                  "secretRef": "postgres-password"
                },
                {
                  "name": "POSTGRES_SSLMODE",
                  "value": "require"
                },
                {
                  "name": "AGENT_SERVICE_URL",
                  "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', parameters('containerAppAgentsName')), '2023-05-01').latestRevisionFqdn)]"
                },
                {
                  "name": "STORAGE_ACCOUNT_NAME",
                  "value": "[parameters('storageAccountName')]"
                },
                {
                  "name": "STORAGE_CONTAINER_NAME",
                  "value": "[parameters('storageContainerName')]"
                },
                {
                  "name": "STORAGE_ACCOUNT_KEY",
                  "secretRef": "storage-key"
                },
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "secretRef": "appinsights-connection-string"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "port": 8000,
                    "path": "/health"
                  },
                  "initialDelaySeconds": 30,
                  "periodSeconds": 15,
                  "timeoutSeconds": 10,
                  "failureThreshold": 3
                },
                {
                  "type": "Readiness",
                  "httpGet": {
                    "port": 8000,
                    "path": "/ready"
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 3,
            "rules": [
              {
                "name": "http-scaling",
                "custom": {
                  "type": "http",
                  "metadata": {
                    "concurrentRequests": "10"
                  }
                }
              }
            ]
          }
        }
      },
      "tags": "[parameters('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.App/containerApps', parameters('containerAppAgentsName'))]",
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-identity', parameters('containerAppUIName')))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerAppAgentsName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-identity', parameters('containerAppAgentsName'))))]": {}
        }
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": false,
            "targetPort": 8000,
            "traffic": [
              {
                "weight": 100,
                "latestRevision": true
              }
            ]
          },
          "secrets": [
            {
              "name": "acr-password",
              "value": "[parameters('acrPassword')]"
            },
            {
              "name": "postgres-password",
              "value": "[parameters('postgresPassword')]"
            },
            {
              "name": "storage-key",
              "value": "[parameters('storageAccountKey')]"
            },
            {
              "name": "openai-key",
              "value": "[parameters('openaiApiKey')]"
            },
            {
              "name": "langsmith-key",
              "value": "[parameters('langSmithApiKey')]"
            },
            {
              "name": "appinsights-connection-string",
              "value": "[parameters('appInsightsConnectionString')]"
            }
          ],
          "registries": [
            {
              "server": "[parameters('acrLoginServer')]",
              "username": "[parameters('acrUsername')]",
              "passwordSecretRef": "acr-password"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "agents",
              "image": "[format('{0}/{1}', parameters('acrLoginServer'), parameters('agentsImageName'))]",
              "resources": {
                "cpu": "[json('1.0')]",
                "memory": "2.0Gi"
              },
              "env": [
                {
                  "name": "FOUNDRY_API_KEY",
                  "secretRef": "openai-key"
                },
                {
                  "name": "OPENAI_API_KEY",
                  "secretRef": "openai-key"
                },
                {
                  "name": "FOUNDRY_ENDPOINT",
                  "value": "[parameters('foundryEndpoint')]"
                },
                {
                  "name": "FOUNDRY_MODEL",
                  "value": "[parameters('foundryModel')]"
                },
                {
                  "name": "LANGCHAIN_API_KEY",
                  "secretRef": "langsmith-key"
                },
                {
                  "name": "LANGCHAIN_TRACING_V2",
                  "value": "true"
                },
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "secretRef": "appinsights-connection-string"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "port": 8000,
                    "path": "/health"
                  },
                  "initialDelaySeconds": 30,
                  "periodSeconds": 15,
                  "timeoutSeconds": 10,
                  "failureThreshold": 3
                },
                {
                  "type": "Readiness",
                  "httpGet": {
                    "port": 8000,
                    "path": "/ready"
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 5,
            "rules": [
              {
                "name": "http-scaling",
                "custom": {
                  "type": "http",
                  "metadata": {
                    "concurrentRequests": "5"
                  }
                }
              }
            ]
          }
        }
