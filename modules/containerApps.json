      "type": "string",
      "defaultValue": "agents:latest",
      "metadata": {
        "description": "Agents image name"
      }
    },
    "openaiApiKey": {
      "type": "securestring",
      "metadata": {
        "description": "OpenAI API key"
      }
    },
    "foundryEndpoint": {
      "type": "string",
      "metadata": {
        "description": "Foundry endpoint URL"
      }
    },
    "foundryModel": {
      "type": "string",
      "defaultValue": "gpt-4mini",
      "metadata": {
        "description": "Foundry deployment/model name"
      }
    },
    "langSmithApiKey": {
      "type": "securestring",
      "metadata": {
        "description": "LangSmith API key"
      }
    }
